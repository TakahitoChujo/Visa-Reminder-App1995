# 環境設定サンプル
# .env にコピーして使用してください（.env はGitにコミットしない！）

# サーバー設定
NODE_ENV=development
PORT=3000

# データベース設定（PostgreSQL）
DB_HOST=localhost
DB_PORT=5432
DB_NAME=visa_reminder
DB_USER=visa_reminder_app
DB_PASSWORD=your_strong_password_here
DB_SSL=false

# または SQLite を使用する場合
# DB_TYPE=sqlite
# DB_PATH=./database.sqlite

# JWT設定
JWT_SECRET=your_jwt_secret_here_generate_with_openssl_rand_hex_32
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

# 暗号化キー（AES-256用、64文字のHEX）
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# または
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-adminsdk.json

# CORS設定
ALLOWED_ORIGINS=http://localhost:3000,https://visa-reminder.app

# レート制限
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# ログレベル
LOG_LEVEL=info

# その他
TIMEZONE=Asia/Tokyo
