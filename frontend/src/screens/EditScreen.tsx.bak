/**
 * 在留カード編集画面
 */

import React, { useState, useEffect } from 'react';
import {
  View,
  Text,
  StyleSheet,
  ScrollView,
  TextInput,
  TouchableOpacity,
  Platform,
  Alert,
} from 'react-native';
import { useNavigation, useRoute } from '@react-navigation/native';
import { Ionicons } from '@expo/vector-icons';
import { useResidenceStore } from '../store/useResidenceStore';
import { ResidenceType } from '../types';
import { theme } from '../theme';
import { format, subMonths, differenceInDays } from 'date-fns';
import { ja } from 'date-fns/locale';
import { DateInput } from '../components/DateInput';

const RESIDENCE_TYPES: { value: ResidenceType; label: string }[] = [
  { value: 'work_visa', label: '技術・人文知識・国際業務' },
  { value: 'spouse_japanese', label: '日本人の配偵者等' },
  { value: 'spouse_permanent', label: '永住者の配偶者等' },
  { value: 'permanent_application', label: '永住申請準備' },
  { value: 'student', label: '留学' },
  { value: 'designated_activities', label: '特定活動' },
  { value: 'skilled_worker', label: '特定技能' },
  { value: 'other', label: 'その他' },
];

export function EditScreen() {
  const navigation = useNavigation();
  const route = useRoute();
  const { cardId } = route.params as { cardId: string };
  const { cards, updateCard, deleteCard } = useResidenceStore();

  const card = cards.find((c) => c.id === cardId);

  const [expirationDate, setExpirationDate] = useState('');
  const [residenceType, setResidenceType] = useState<ResidenceType | ''>('');
  const [memo, setMemo] = useState('');
  const [showTypePicker, setShowTypePicker] = useState(false);

  useEffect(() => {
    if (card) {
      setExpirationDate(card.expirationDate);
      setResidenceType(card.residenceType);
      setMemo(card.memo || '');
    }
  }, [card]);

  const handleSave = async () => {
    if (!expirationDate || !residenceType) {
      Alert.alert('エラー', '有効期限と資格タイプを入力してください');
      return;
    }

    try {
      await updateCard(cardId, {
        expirationDate,
        residenceType,
        memo,
      });

      Alert.alert('成功', '在留資格を更新しました', [
        { text: 'OK', onPress: () => navigation.goBack() },
      ]);
    } catch (error) {
      Alert.alert('エラー', '更新に失敗しました');
    }
  };

  const handleDelete = () => {
    Alert.alert(
      '確認',
      'この在留資格を削除してもよろしいですか？',
      [
        { text: 'キャンセル', style: 'cancel' },
        {
          text: '削除',
          style: 'destructive',
          onPress: async () => {
            await deleteCard(cardId);
            navigation.goBack();
          },
        },
      ]
    );
  };

  const getApplicationStartDate = () => {
    if (!expirationDate) return null;
    return subMonths(new Date(expirationDate), 4);
  };

  const getDaysRemaining = () => {
    if (!expirationDate) return null;
    return differenceInDays(new Date(expirationDate), new Date());
  };

  const selectedType = RESIDENCE_TYPES.find((t) => t.value === residenceType);

  if (!card) {
    return (
      <View style={styles.container}>
        <Text>カードが見つかりません</Text>
      </View>
    );
  }

  return (
    <View style={styles.container}>
      {/* Header */}
      <View style={styles.header}>
        <TouchableOpacity style={styles.backButton} onPress={() => navigation.goBack()}>
          <Ionicons name="chevron-back" size={24} color={theme.colors.textPrimary} />
        </TouchableOpacity>
        <Text style={styles.headerTitle}>在留資格の編集</Text>
        <TouchableOpacity style={styles.saveButton} onPress={handleSave}>
          <Text style={styles.saveButtonText}>保存</Text>
        </TouchableOpacity>
      </View>

      <ScrollView
        style={styles.content}
        contentContainerStyle={styles.contentContainer}
      >
        {/* 基本情報セクション */}
        <View style={styles.section}>
          <View style={styles.sectionHeader}>
            <Ionicons name="document-text-outline" size={24} color={theme.colors.primary} />
            <Text style={styles.sectionTitle}>基本情報</Text>
          </View>

          {/* 有効期限 */}
          <View style={styles.formGroup}>
            <Text style={styles.label}>
              有効期限<Text style={styles.required}>*</Text>
            </Text>
            <DateInput
              value={expirationDate}
              onChange={setExpirationDate}
              placeholder="日付を選択してください"
            />
            <View style={styles.helper}>
              <Ionicons name="information-circle-outline" size={14} color={theme.colors.textSecondary} />
              <Text style={styles.helperText}>
                {Platform.OS === 'web'
                  ? 'カレンダーアイコンをクリックして日付を選択してください'
                  : 'カレンダーアイコンをタップして日付を選択してください'
                }
              </Text>
            </View>
          </View>

          {/* 資格タイプ */}
          <View style={styles.formGroup}>
            <Text style={styles.label}>
              資格タイプ<Text style={styles.required}>*</Text>
            </Text>
            <TouchableOpacity
              style={styles.picker}
              onPress={() => setShowTypePicker(!showTypePicker)}
            >
              <Text style={[styles.pickerText, !residenceType && styles.pickerPlaceholder]}>
                {selectedType?.label || '選択してください'}
              </Text>
              <Ionicons name="chevron-down" size={20} color={theme.colors.textSecondary} />
            </TouchableOpacity>

            {showTypePicker && (
              <View style={styles.pickerOptions}>
                {RESIDENCE_TYPES.map((type) => (
                  <TouchableOpacity
                    key={type.value}
                    style={styles.pickerOption}
                    onPress={() => {
                      setResidenceType(type.value);
                      setShowTypePicker(false);
                    }}
                  >
                    <Text style={styles.pickerOptionText}>{type.label}</Text>
                    {residenceType === type.value && (
                      <Ionicons name="checkmark" size={20} color={theme.colors.primary} />
                    )}
                  </TouchableOpacity>
                ))}
              </View>
            )}
          </View>
        </View>

        {/* 期限情報プレビュー */}
        {expirationDate && (
          <View style={styles.section}>
            <View style={styles.sectionHeader}>
              <Ionicons name="calendar-outline" size={24} color={theme.colors.primary} />
              <Text style={styles.sectionTitle}>期限情報</Text>
            </View>

            <View style={styles.datePreview}>
              <View style={styles.dateRow}>
                <Text style={styles.dateLabel}>有効期限</Text>
                <Text style={[styles.dateValue, styles.dateValueHighlight]}>
                  {format(new Date(expirationDate), 'yyyy年M月d日', { locale: ja })}
                </Text>
              </View>
              <View style={styles.dateRow}>
                <Text style={styles.dateLabel}>申請可能開始日（目安）</Text>
                <Text style={styles.dateValue}>
                  {getApplicationStartDate() ? format(getApplicationStartDate()!, 'yyyy年M月d日', { locale: ja }) : '-'}
                </Text>
              </View>
              <View style={styles.dateRow}>
                <Text style={styles.dateLabel}>残り日数</Text>
                <Text style={styles.dateValue}>{getDaysRemaining() ?? 0}日</Text>
              </View>
            </View>
          </View>
        )}

        {/* メモ */}
        <View style={styles.section}>
          <View style={styles.sectionHeader}>
            <Ionicons name="create-outline" size={24} color={theme.colors.primary} />
            <Text style={styles.sectionTitle}>メモ（任意）</Text>
          </View>

          <View style={styles.formGroup}>
            <Text style={styles.label}>メモ</Text>
            <TextInput
              style={[styles.input, styles.textArea]}
              placeholder="必要に応じてメモを入力してください"
              value={memo}
              onChangeText={setMemo}
              multiline
              numberOfLines={4}
              placeholderTextColor={theme.colors.textTertiary}
            />
          </View>
        </View>

        {/* 削除ボタン */}
        <View style={styles.section}>
          <TouchableOpacity style={styles.deleteButton} onPress={handleDelete}>
            <Ionicons name="trash-outline" size={20} color={theme.colors.error} />
            <Text style={styles.deleteButtonText}>この在留資格を削除</Text>
          </TouchableOpacity>
        </View>
      </ScrollView>

      {/* Bottom Actions */}
      <View style={styles.bottomActions}>
        <TouchableOpacity style={styles.primaryButton} onPress={handleSave}>
          <Ionicons name="checkmark" size={20} color={theme.colors.textWhite} />
          <Text style={styles.primaryButtonText}>更新する</Text>
        </TouchableOpacity>
        <TouchableOpacity style={styles.secondaryButton} onPress={() => navigation.goBack()}>
          <Text style={styles.secondaryButtonText}>キャンセル</Text>
        </TouchableOpacity>
      </View>
    </View>
  );
}

// スタイルはRegisterScreenと同じものを使用
