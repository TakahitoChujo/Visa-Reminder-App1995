    fontWeight: theme.fontWeight.semibold,
    color: theme.colors.primary,
  },
  content: {
    flex: 1,
  },
  contentContainer: {
    padding: theme.spacing.lg,
    paddingBottom: 100, // ボトムアクションのための余白
  },
